LLM_GATEWAY_BASE_URL=https://api.deepseek.com/v1
LLM_GATEWAY_API_KEY=replace-me
LLM_GATEWAY_MODEL=deepseek-chat
LLM_GATEWAY_TIMEOUT_SECONDS=60
LLM_GATEWAY_VERIFY_SSL=true

# Optional. Use x-api-key if your gateway does not accept Authorization: Bearer.
LLM_GATEWAY_AUTH_HEADER=authorization
LLM_GATEWAY_EXTRA_HEADERS_JSON={}
